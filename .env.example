# Firebase configuration for the public review system.
# Rename this file to .env and add your Firebase project values.
# Restart the Vite dev server after changing any of these values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: for local development you can also configure a Vercel project.
# Add the same values in Vercel > Project Settings > Environment Variables.
